# =============================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 로 보호되어 절대 커밋되지 않습니다.
# Claude 에서 `/setup-keys` 슬래시 커맨드를 실행하면 대화형으로
# 자동 입력할 수 있습니다.
# =============================================================

# --- Qualtrics ---
# 발급: Qualtrics → 우상단 계정 아이콘 → Account Settings → Qualtrics IDs → API
# (예: ABC123def456…  44자 영숫자)
QUALTRICS_API_TOKEN=

# 데이터 센터 ID. 같은 페이지 "User" 박스의 "Datacenter ID" 값.
# 예: yul1 (캐나다), fra1 (프랑크푸르트), sjc1 (실리콘밸리), iad1 (버지니아)
QUALTRICS_DATA_CENTER=

# --- Prolific ---
# 발급: https://app.prolific.com → Settings → Go to API tokens → Create token
PROLIFIC_API_TOKEN=

# Workspace ID: Prolific 대시보드 URL 의 /workspaces/<여기> 부분 (24자리 영숫자)
# → 토큰만 채운 뒤 Claude 에서 `/find-prolific-ids` 를 쓰면 자동으로 찾아 넣어줍니다.
PROLIFIC_WORKSPACE_ID=

# Project ID: 워크스페이스 안에서 프로젝트를 열면 URL 의 /projects/<여기> (24자리 영숫자)
# → 프로젝트가 없으면 Prolific 대시보드의 "New project" 로 먼저 생성하세요.
PROLIFIC_PROJECT_ID=
